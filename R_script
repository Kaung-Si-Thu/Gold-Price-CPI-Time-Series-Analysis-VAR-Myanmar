# =============================================================================
# 4. Unit root tests (ADF & PP) at level and first difference
# =============================================================================
cat("\n", paste(rep("=", 60), collapse = ""), "\n")
cat("Unit Root Tests at Level\n")
cat(paste(rep("=", 60), collapse = ""), "\n")

# Augmented Dickey-Fuller test
adf_gold <- adf.test(ts_loggold, alternative = "stationary")
adf_cpi <- adf.test(ts_cpi, alternative = "stationary")

cat("\n--- Log Gold Price ---\n")
print(adf_gold)
cat("\n--- CPI ---\n")
print(adf_cpi)

# Phillips-Perron test (from tseries package)
pp_gold <- pp.test(ts_loggold, alternative = "stationary")
pp_cpi <- pp.test(ts_cpi, alternative = "stationary")

cat("\n--- Phillips-Perron Test ---\n")
cat("Log Gold:\n")
print(pp_gold)
cat("CPI:\n")
print(pp_cpi)

# First differencing
d_loggold <- diff(ts_loggold)
d_cpi <- diff(ts_cpi)

cat("\n", paste(rep("=", 60), collapse = ""), "\n")
cat("Unit Root Tests at First Difference\n")
cat(paste(rep("=", 60), collapse = ""), "\n")

adf_dgold <- adf.test(d_loggold, alternative = "stationary")
adf_dcpi <- adf.test(d_cpi, alternative = "stationary")
cat("\n--- Δ Log Gold Price ---\n")
print(adf_dgold)
cat("\n--- Δ CPI ---\n")
print(adf_dcpi)

pp_dgold <- pp.test(d_loggold, alternative = "stationary")
pp_dcpi <- pp.test(d_cpi, alternative = "stationary")
cat("\n--- Phillips-Perron on differences ---\n")
cat("Δ Log Gold:\n")
print(pp_dgold)
cat("Δ CPI:\n")
print(pp_dcpi)

# =============================================================================
# 5. Johansen cointegration test (on levels)
# =============================================================================
# Combine the two series into a matrix for urca
johansen_data <- cbind(ts_loggold, ts_cpi)
# Use a lag length of 2 (as in thesis) and include a constant in the cointegration equation
# Note: k = lag order in the VAR (i.e., number of lags of differences) – here we choose 2 based on earlier selection
# The thesis uses 2 lags in the VAR; for Johansen, we set K = 2 (lag order for the VAR)
coint_test <- ca.jo(johansen_data, type = "trace", ecdet = "const", K = 2, spec = "longrun")

cat("\n", paste(rep("=", 60), collapse = ""), "\n")
cat("Johansen Cointegration Test\n")
cat(paste(rep("=", 60), collapse = ""), "\n")
summary(coint_test)

# =============================================================================
# 6. Optimal lag length selection for VAR (using stationary series)
# =============================================================================
# Use differenced data (both I(1) and not cointegrated)
var_data <- cbind(d_loggold, d_cpi)

# Lag selection criteria up to 12 lags
lag_select <- VARselect(var_data, lag.max = 12, type = "const")
cat("\n", paste(rep("=", 60), collapse = ""), "\n")
cat("Lag Length Selection (VAR on first differences)\n")
cat(paste(rep("=", 60), collapse = ""), "\n")
print(lag_select$criteria)
cat("\nSelected lag by AIC: ", lag_select$selection["AIC(n)"], "\n")

# We'll use the lag suggested by AIC (or the majority from thesis: 2)
p <- 2   # as per thesis (Table 4.4)
cat("Using lag = ", p, " (based on thesis)\n")

# =============================================================================
# 7. Estimate VAR model on stationary data
# =============================================================================
var_est <- VAR(var_data, p = p, type = "const")
cat("\n", paste(rep("=", 60), collapse = ""), "\n")
cat("VAR(2) Model Estimation\n")
cat(paste(rep("=", 60), collapse = ""), "\n")
summary(var_est)

# =============================================================================
# 8. Stability check (eigenvalues of companion matrix)
# =============================================================================
roots <- roots(var_est)
cat("\n", paste(rep("=", 60), collapse = ""), "\n")
cat("Stability Check – Inverse Roots of Characteristic Polynomial\n")
cat(paste(rep("=", 60), collapse = ""), "\n")
print(roots)
cat("All moduli < 1? ", all(Mod(roots) < 1), "\n")
if(all(Mod(roots) < 1)) cat("=> Model is stable\n") else cat("=> Model is unstable\n")

# =============================================================================
# 9. Residual diagnostics: LM test for autocorrelation
# =============================================================================
cat("\n", paste(rep("=", 60), collapse = ""), "\n")
cat("LM Test for Residual Autocorrelation (up to lag 5)\n")
cat(paste(rep("=", 60), collapse = ""), "\n")
serial_test <- serial.test(var_est, lags.pt = 5, type = "PT.asymptotic")
print(serial_test)

# =============================================================================
# 10. Granger causality tests (Table 4.10)
# =============================================================================
cat("\n", paste(rep("=", 60), collapse = ""), "\n")
cat("Granger Causality Tests\n")
cat(paste(rep("=", 60), collapse = ""), "\n")

# Test if d_loggold Granger-causes d_cpi
causality_gold_to_cpi <- causality(var_est, cause = "d_loggold")
cat("\nH0: Gold price does NOT Granger-cause CPI\n")
print(causality_gold_to_cpi$Granger)

# Test if d_cpi Granger-causes d_loggold
causality_cpi_to_gold <- causality(var_est, cause = "d_cpi")
cat("\nH0: CPI does NOT Granger-cause gold price\n")
print(causality_cpi_to_gold$Granger)

