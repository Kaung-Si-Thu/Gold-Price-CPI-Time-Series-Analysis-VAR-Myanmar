# =============================================================================
# Gold Price and CPI Analysis – Myanmar (2012-2022)
# Replication of thesis: ANALYZING THE RELATIONSHIP BETWEEN 24 CARAT GOLD PRICE AND CONSUMER PRICE INDEX IN MYANMAR
# Author: Kaung Si Thu
# =============================================================================

# Load required packages
library(tidyverse)   # data manipulation and plotting
library(tseries)     # ADF and PP tests
library(urca)        # Johansen cointegration test
library(vars)        # VAR model, lag selection, causality, serial test
library(lmtest)      # additional diagnostics
library(forecast)    # for auto.arima (optional)

# =============================================================================
# 1. Load and prepare data
# =============================================================================
# Expected CSV format: Date, GoldPrice, CPI
# Date should be in YYYY-MM-DD format (monthly)
data <- read.csv("myanmar_gold_cpi.csv", stringsAsFactors = FALSE)

# Convert Date column to Date object and sort
data$Date <- as.Date(data$Date)
data <- data[order(data$Date), ]

# Check for missing values
cat("Missing values:\n")
print(colSums(is.na(data)))

# Remove any rows with missing values
data <- na.omit(data)

# Take natural log of gold price for better scaling
data$LogGold <- log(data$GoldPrice)
data$CPI <- data$CPI   # already an index

# Create time series objects (monthly, start = first date)
start_date <- data$Date[1]
start_year <- as.numeric(format(start_date, "%Y"))
start_month <- as.numeric(format(start_date, "%m"))

# Convert to ts objects for easier plotting and differencing
ts_gold <- ts(data$GoldPrice, start = c(start_year, start_month), frequency = 12)
ts_loggold <- ts(data$LogGold, start = c(start_year, start_month), frequency = 12)
ts_cpi <- ts(data$CPI, start = c(start_year, start_month), frequency = 12)

# =============================================================================
# 2. Descriptive statistics (Table 4.1)
# =============================================================================
cat("\n", paste(rep("=", 60), collapse = ""), "\n")
cat("Descriptive Statistics (April 2012 – July 2022)\n")
cat(paste(rep("=", 60), collapse = ""), "\n")

desc_stats <- data %>%
  summarise(
    Mean_Gold = mean(GoldPrice),
    Median_Gold = median(GoldPrice),
    SD_Gold = sd(GoldPrice),
    Skew_Gold = skewness(GoldPrice),
    Kurt_Gold = kurtosis(GoldPrice),
    Min_Gold = min(GoldPrice),
    Max_Gold = max(GoldPrice),
    Mean_CPI = mean(CPI),
    Median_CPI = median(CPI),
    SD_CPI = sd(CPI),
    Skew_CPI = skewness(CPI),
    Kurt_CPI = kurtosis(CPI),
    Min_CPI = min(CPI),
    Max_CPI = max(CPI)
  )

# Helper functions for skewness and kurtosis (if not already in psych package)
skewness <- function(x) {
  n <- length(x)
  m3 <- sum((x - mean(x))^3) / n
  s3 <- sd(x)^3
  m3 / s3
}
kurtosis <- function(x) {
  n <- length(x)
  m4 <- sum((x - mean(x))^4) / n
  s4 <- sd(x)^4
  m4 / s4 - 3   # excess kurtosis
}

desc_stats <- data %>%
  summarise(
    Mean_Gold = mean(GoldPrice),
    Median_Gold = median(GoldPrice),
    SD_Gold = sd(GoldPrice),
    Skew_Gold = skewness(GoldPrice),
    Kurt_Gold = kurtosis(GoldPrice),
    Min_Gold = min(GoldPrice),
    Max_Gold = max(GoldPrice),
    Mean_CPI = mean(CPI),
    Median_CPI = median(CPI),
    SD_CPI = sd(CPI),
    Skew_CPI = skewness(CPI),
    Kurt_CPI = kurtosis(CPI),
    Min_CPI = min(CPI),
    Max_CPI = max(CPI)
  )
print(round(desc_stats, 2))

# =============================================================================
# 3. Time series plots (Figures 4.1 & 4.2)
# =============================================================================
par(mfrow = c(2, 1), mar = c(4, 4, 2, 1))
plot(ts_gold, main = "24 Carat Gold Price (Kyats per ounce)",
     ylab = "Kyats/ounce", col = "darkgoldenrod", lwd = 2)
grid()
plot(ts_cpi, main = "Consumer Price Index (CPI)",
     ylab = "Index", col = "steelblue", lwd = 2)
grid()
par(mfrow = c(1, 1))

